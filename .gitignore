# =============================================================
# CRIS DB Agent — .gitignore
#
# HOW TO RUN WITHOUT DOCKER:
#   1. pip install -r requirements.txt
#   2. python build_db.py        (downloads trains.json & builds railway.db)
#   3. streamlit run app.py
#
# stations.json is committed (small, 19 KB).
# trains.json and railway.db are ignored (large files, regenerated by build_db.py).
# =============================================================

# ---------------------------
# Large data files (regenerate via build_db.py)
# ---------------------------
trains.json
railway.db

# ---------------------------
# Python virtual environments
# ---------------------------
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ---------------------------
# Python cache & compiled files
# ---------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# ---------------------------
# Distribution / packaging
# ---------------------------
build/
dist/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
wheels/
share/python-wheels/

# ---------------------------
# Testing & coverage
# ---------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.tox/
.coverage
coverage.xml

# ---------------------------
# Jupyter
# ---------------------------
.ipynb_checkpoints

# ---------------------------
# Editors & IDEs
# ---------------------------
.vscode/
.idea/
*.swp
*.swo
.project
.pydevproject
.settings/

# ---------------------------
# OS-generated files
# ---------------------------
.DS_Store
Thumbs.db
ehthumbs.db
._*

# ---------------------------
# Environment / secrets
# ---------------------------
.env
.env.local
*.secret

# ---------------------------
# Logs
# ---------------------------
*.log
