# =============================================================
# CRIS DB Agent — .gitignore
# =============================================================

# ---------------------------
# ⚠️  SECRETS — Never commit these
# ---------------------------
.streamlit/secrets.toml
.env
.env.local
*.secret

# ---------------------------
# Database files (regenerate via build_db.py)
# ---------------------------
*.db
*.sqlite
*.sqlite3

# ---------------------------
# Raw data files (large, regenerated locally)
# ---------------------------
trains.json

# ---------------------------
# Local CSV uploads
# ---------------------------
uploads/
*.csv

# ---------------------------
# ChromaDB vector store (persisted locally, rebuilt at runtime)
# ---------------------------
chroma_db/
chromadb/
.chroma/

# ---------------------------
# Python virtual environments
# ---------------------------
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ---------------------------
# Python cache & compiled files
# ---------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# ---------------------------
# Distribution / packaging
# ---------------------------
build/
dist/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
wheels/
share/python-wheels/

# ---------------------------
# Testing & coverage
# ---------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.tox/
.coverage
coverage.xml

# ---------------------------
# Jupyter
# ---------------------------
.ipynb_checkpoints

# ---------------------------
# Editors & IDEs
# ---------------------------
.vscode/
.idea/
*.swp
*.swo
.project
.pydevproject
.settings/

# ---------------------------
# OS-generated files
# ---------------------------
.DS_Store
Thumbs.db
ehthumbs.db
._*

# ---------------------------
# Logs
# ---------------------------
*.log